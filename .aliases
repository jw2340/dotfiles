# ----------------------
# Aliases
# ----------------------
alias create-mfa-creds="fabric aws-mfa::create-credentials"

# runs task-minder.sh on a command to say done or error
alias mind="sh $HOME/task-minder.sh"

alias -s txt=textedit

alias -g G="| grep"

# Git
alias glom='git pull origin master'
alias gcbom=git_checkout_branch_from_origin_master
alias grsh='git reset --soft HEAD@{1}'
